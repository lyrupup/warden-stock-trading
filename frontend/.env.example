# 后端 API 基地址（统一响应体 {code,message,data}）
VITE_API_BASE_URL=http://localhost:8080/api

# V1 单用户模式：为 true 时自动注入默认 token 并跳过登录守卫
VITE_SINGLE_USER_MODE=true

# 单用户模式下注入的默认 token（与后端约定）
VITE_DEFAULT_TOKEN=dev-single-user-token

# AI 流式接口路径（SSE）
VITE_SSE_PATH=/api/ai/stream

# 是否启用 MSW Mock（脱离后端开发联调）。生产请置为 false 或不设置
VITE_ENABLE_MOCK=true
