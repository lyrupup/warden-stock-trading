# 守望者后端环境变量示例（见 BACKEND.md §7.2）
# 复制为 .env 并按需修改；环境变量优先级高于 config/config.yaml

APP_PORT=8080
SINGLE_USER_MODE=true
APP_ENV=dev
JWT_SECRET=change_me
CONFIG_ENC_KEY=32_bytes_key_for_aes_gcm________

# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DB=warden
PG_SSLMODE=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis123
REDIS_DB=0

# 行情数据源
MARKET_PROVIDER=gotdx          # gotdx(主力,直连通达信)|tushare；默认构建回退 stub
MARKET_GOTDX_MAX_CONN=8        # gotdx 连接池大小
TUSHARE_TOKEN=                 # 仅当用 tushare 或作补充校验时

# 外部集成（也可走 M7 用户级配置覆盖）
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
